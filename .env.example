# LLM Provider: "portkey" (default) or "anthropic"
LLM_PROVIDER=portkey

# Portkey AI Gateway (default provider)
PORTKEY_API_KEY=...
# Provider slug from Portkey Model Catalog (e.g. @vertex-ai, @gcp-global)
PORTKEY_PROVIDER=@gcp-global
# Optional model override
LLM_MODEL=anthropic.claude-sonnet-4-20250514

# Anthropic API key (only needed if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# NewsAPI.org API key (free tier: 100 requests/day)
NEWS_API_KEY=...

# Secret for external cron trigger endpoint
CRON_SECRET=change-me-to-a-random-string
