{
  "name": "news-aggregator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "start": "nuxt preview",
    "preview": "wrangler pages dev dist",
    "deploy": "nuxt build && wrangler pages deploy dist",
    "d1:create": "wrangler d1 create news-aggregator-db",
    "d1:migrate": "wrangler d1 migrations apply news-aggregator-db --local",
    "d1:migrate:remote": "wrangler d1 migrations apply news-aggregator-db --remote"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "cheerio": "^1.2.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "nanoid": "^5.1.7",
    "nuxt": "^4.4.2",
    "portkey-ai": "^3.0.3",
    "reka-ui": "^2.9.2",
    "vue": "^3.5.30",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "nitro-cloudflare-dev": "^0.2.2",
    "tailwindcss": "^4.2.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.76.0"
  }
}
